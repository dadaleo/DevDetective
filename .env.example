# ─── DevDetective 环境变量 ───
# 复制此文件为 .env.local 并填入你的 Key

# ─── AI Provider（至少配置一个） ───
# 主 Provider: DeepSeek（推荐，兼容 OpenAI SDK）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 备选 Provider: OpenAI 或任何兼容 API
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# 辅助 Provider: NVIDIA NIM（README 批量总结分流，可选）
# NVIDIA_API_KEY=nvapi-your-nvidia-api-key

# ─── GitHub ───
# GitHub Personal Access Token（必填，否则 60次/小时限制）
# 获取: https://github.com/settings/tokens → Generate new token (classic) → 勾选 public_repo
GITHUB_TOKEN=ghp_your-github-token

# ─── 应用配置 ───
NEXT_PUBLIC_APP_NAME=DevDetective
DATABASE_URL=./data/devdetective.sqlite

# ─── 托管体验版开关（部署到 ai2work.xyz 时再启用） ───
# true: 启用轻量体验版限制（默认 Top 5 + 每日 3 次）
# false: 本地开源完整版
HOSTED_EXPERIENCE_MODE=false
HOSTED_DAILY_LIMIT=3
HOSTED_MAX_RESULTS=5
