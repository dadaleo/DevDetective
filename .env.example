# DevDetective environment variables
# Copy this file to .env.local and fill in your own keys.

# Required: AI provider
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Required: GitHub API token for stable quota
GITHUB_TOKEN=ghp_your-github-token

# Optional: OpenAI-compatible provider
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: NVIDIA NIM provider
# NVIDIA_API_KEY=nvapi-your-nvidia-api-key

# App identity
NEXT_PUBLIC_APP_NAME=DevDetective

# Local default: keep empty when running at the domain root
NEXT_PUBLIC_BASE_PATH=

# Subpath deployment example:
# NEXT_PUBLIC_BASE_PATH=/devdetective

# Local database file
DATABASE_URL=./data/devdetective.sqlite

# Hosted experience mode
# false: local full version
# true: hosted demo mode
HOSTED_EXPERIENCE_MODE=false
HOSTED_LIMIT_WINDOW_HOURS=6
HOSTED_MAX_QUERIES_PER_WINDOW=2
HOSTED_MAX_RESULTS=5
