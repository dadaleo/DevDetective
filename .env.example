# DevDetective environment variables
# Copy this file to .env.local and fill in your own keys.

# AI provider (required)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Optional compatible provider
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional NVIDIA NIM provider
# NVIDIA_API_KEY=nvapi-your-nvidia-api-key

# GitHub token (required for stable API quota)
GITHUB_TOKEN=ghp_your-github-token

# App config
NEXT_PUBLIC_APP_NAME=DevDetective
NEXT_PUBLIC_BASE_PATH=
DATABASE_URL=./data/devdetective.sqlite

# Hosted experience mode
# false: local full version
# true: hosted demo mode for ai2work.xyz
HOSTED_EXPERIENCE_MODE=false
HOSTED_LIMIT_WINDOW_HOURS=6
HOSTED_MAX_QUERIES_PER_WINDOW=2
HOSTED_MAX_RESULTS=5
